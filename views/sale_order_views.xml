<odoo>
    <record id="view_sale_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Inserta el botón en una ubicación válida dentro de la vista -->
            <xpath expr="//header" position="inside">
                <button name="generar_presupuesto_pdf" type="object" string="Generar Presupuesto PDF"/>
            </xpath>

            <!-- Ocultar el campo original de plazo de pago -->
            <xpath expr="//field[@name='payment_term_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Agregar el campo "Forma de pago" después del campo "Plazos de pago" -->
            <xpath expr="//field[@name='validity_date']" position="after">
                <field name="payment_method" placeholder="Especificar forma de pago" />
            </xpath>

            <!-- Agregar el campo "Texto Editable Pagina 1" después del campo "partner_id" -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="text_pagina1" placeholder="Rellenar texto pagina 1" widget="char_length_counter" attrs="{'required': [('is_desarrollo_web', '=', False)], 'invisible': [('is_desarrollo_web', '=', True)]}"/>
                <field name="text_pagina1_web" placeholder="Rellenar especificaciones para Desarrollo Web (3 renglones)" widget="char_length_counter" attrs="{'required': [('is_desarrollo_web', '=', True)], 'invisible': [('is_desarrollo_web', '=', False)]}"/>
            </xpath>

            <!-- Agregar el campo "Texto Editable Pagina 2" después del campo "texto pagina 1" -->
            <xpath expr="//field[@name='text_pagina1']" position="after">
                <field name="text_pagina2" placeholder="Rellenar texto pagina 2" widget="char_length_counter" required="1"/>
            </xpath>

            <!-- Insertar el nuevo campo en el mismo lugar -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="plazo_ejecucion"/>
                <field name="is_desarrollo_web" invisible="1"/>
                <field name="valor_cuota1" attrs="{'invisible': [('is_desarrollo_web', '=', False)]}"/>
                <field name="valor_cuota2" attrs="{'invisible': [('is_desarrollo_web', '=', False)]}"/>
                <field name="valor_cuota3" attrs="{'invisible': [('is_desarrollo_web', '=', False)]}"/>
            </xpath>
        </field>
    </record>
</odoo>
